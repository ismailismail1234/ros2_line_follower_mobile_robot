<launch>

  <!-- Paths -->
  <let name="urdf_path"
       value="$(find-pkg-share my_robot_description)/urdf/my_robot.urdf.xacro"/>

  <let name="rviz_config_path"
       value="$(find-pkg-share my_robot_bringup)/rviz/urdf_config.rviz"/>

  <let name="world_path"
       value="$(find-pkg-share my_robot_worlds)/worlds/line_follower.world"/>

  <!-- Robot state publisher -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
    <param name="use_sim_time" value="true"/>
    <param name="robot_description"
           value="$(command 'xacro $(var urdf_path)')"/>
  </node>

  <!-- Gazebo (CORRECT WAY FOR HUMBLE) -->
  <include file="$(find-pkg-share gazebo_ros)/launch/gazebo.launch.py">
    <arg name="world" value="$(var world_path)"/>
  </include>

  <!-- Spawn robot -->
  <node pkg="gazebo_ros" exec="spawn_entity.py" output="screen"
        args="-entity my_robot -topic robot_description -x 0 -y 0 -z 0.5"/>

  <!-- RViz -->
  <node pkg="rviz2" exec="rviz2" output="screen"
        args="-d $(var rviz_config_path)"/>

</launch>